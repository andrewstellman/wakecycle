      },
      {
        "task_id": "stop-2",
        "target_repo": "{SCENARIO_DIR}",
        "dispatch_mode": "shell",
        "worker_prompt": "stub stop-2",
        "worker_cmd": [
          "python3",
          "{STUB}",
          "--heartbeat",
          "{HEARTBEAT_PATH}",
          "--task-id",
          "{TASK_ID}",
          "--run-dir",
          "{RUN_DIR}",
          "--steps",
          "1",
          "--sleep",
          "0.2"
        ]
      }
    ]
  },
  "control": {
