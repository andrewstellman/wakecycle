{
  "description": "PAUSE mid-run: a slot frees (entry-1 completes) but the queued entry-2 is NOT dispatched while paused; the run stays paused and not done across several ticks.",
  "plan": {
    "schema_version": "1",
    "tick_interval_minutes": 1,
    "pool_size": 1,
    "stall_threshold_minutes": 45,
    "launch_grace_minutes": 10,
    "entries": [
      {
        "task_id": "pr-1",
        "target_repo": "{SCENARIO_DIR}",
        "dispatch_mode": "shell",
        "worker_prompt": "stub pr-1",
        "worker_cmd": [
          "python3",
          "{STUB}",
          "--heartbeat",
          "{HEARTBEAT_PATH}",
          "--task-id",
          "{TASK_ID}",
          "--run-dir",
          "{RUN_DIR}",
          "--steps",
          "1",
          "--sleep",
          "0.2"
        ]
      },
      {
        "task_id": "pr-2",
        "target_repo": "{SCENARIO_DIR}",
        "dispatch_mode": "shell",
        "worker_prompt": "stub pr-2",
        "worker_cmd": [
          "python3",
          "{STUB}",
          "--heartbeat",
          "{HEARTBEAT_PATH}",
          "--task-id",
          "{TASK_ID}",
          "--run-dir",
          "{RUN_DIR}",
          "--steps",
          "1",
          "--sleep",
          "0.2"
        ]
      }
    ]
  },
  "control": {
    "write_pause_after_tick": 1,
    "max_ticks": 6
  },
  "expected": {
    "done": false,
    "paused": true,
    "counts": {
      "completed": 1
    },
    "run_states": {
      "run-01": "completed",
      "run-02": "queued"
    }
  }
}